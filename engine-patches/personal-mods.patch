+    {
+        const char *want = "mellon";
+        bool match = true;
+        for (int n = 0; n < 7; n++) {
+            char c = py.misc.name[n];
+            if (c >= 'A' && c <= 'Z') {
+                c = (char) (c + 32);
+            }
+            if (c != want[n]) {
+                match = false;
+                break;
+            }
+        }
+        if (match) {
+            Inventory_t sting{};
+            inventoryItemCopyTo(28, sting); // Dagger (Main Gauche), our "Sting"
+            itemIdentifyAsStoreBought(sting);
+            sting.to_hit = 5;
+            sting.to_damage = 5;
+            sting.identification |= config::identification::ID_SHOW_HIT_DAM;
+            (void) inventoryCarryItem(sting);
+
+            Inventory_t phial{};
+            inventoryItemCopyTo(364, phial); // Brass Lantern, our "Phial of Galadriel"
+            itemIdentifyAsStoreBought(phial);
+            phial.misc_use = 15000;
+            (void) inventoryCarryItem(phial);
+        }
+    }
