+// UMORIA personal mod: resurrect the player in town, stripped to a bare kit.
+static void playerResurrectInTown() {
+    py.misc.lives--;
+    game.character_is_dead = false;
+    eof_flag = 0;
+
+    // strip the entire pack and all worn equipment
+    for (auto &entry : py.inventory) {
+        inventoryItemCopyTo(config::dungeon::objects::OBJ_NOTHING, entry);
+    }
+    py.pack.unique_items = 0;
+    py.pack.heaviness = 0;
+    py.equipment_count = 0;
+
+    // hand back only a dagger, a small shield, a few torches and some food
+    const uint16_t kit[4] = {30, 129, 365, 344}; // Stiletto, Small Metal Shield, Wooden Torch, Ration
+    for (int i = 0; i < 4; i++) {
+        Inventory_t item{};
+        inventoryItemCopyTo(kit[i], item);
+        itemIdentifyAsStoreBought(item);
+        if (kit[i] == 365) {
+            item.items_count = 3;
+        }
+        if (kit[i] == 344) {
+            item.items_count = 2;
+        }
+        (void) inventoryCarryItem(item);
+    }
+
+    // lose all gold, restore the body, clear afflictions
+    py.misc.au = 0;
+    py.misc.current_hp = py.misc.max_hp;
+    py.misc.current_hp_fraction = 0;
+    py.misc.current_mana = py.misc.mana;
+    py.misc.current_mana_fraction = 0;
+    py.flags.food = 5000;
+    py.flags.status = 0;
+    py.flags.rest = 0;
+    py.flags.poisoned = 0;
+    py.flags.blind = 0;
+    py.flags.paralysis = 0;
+    py.flags.afraid = 0;
+    py.flags.confused = 0;
+    py.flags.image = 0;
+    py.flags.slow = 0;
+    py.flags.fast = 0;
+
+    playerRecalculateBonuses();
+
+    dg.current_level = 0; // back to the town
+
+    printMessage("Death takes you... but the Fates are not yet done with you.");
+    printMessage("Temple acolytes drag your body back to the town square.");
+
+    char msg[80];
+    (void) snprintf(msg, sizeof(msg), "Your gold and goods are gone. Lives remaining: %d", py.misc.lives + 1);
+    printMessage(msg);
+}
